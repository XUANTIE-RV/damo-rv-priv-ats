# =====================================================================
# Common build rules for RISC-V Privilege Test Framework
# =====================================================================
#
# Include this from each extension's Makefile:
#   include ../common/Makefile.common
#
# Extensions must define ONE of:
#   Single-target mode (legacy):
#     TARGET    - output binary name (e.g., pmp_test.elf)
#     EXT_OBJS  - extension-specific object files
#
#   Multi-target mode:
#     TARGETS   - list of output binaries (e.g., pmp_cvpt.elf pmp_basic.elf)
#     <base>_OBJS - per-target object files (e.g., pmp_cvpt_OBJS = ...)
#       where <base> is the filename without .elf, with - and . replaced by _
#
# =====================================================================

# Default configuration (CONFIG must be resolved before including platform.mk)
CONFIG ?= qemu-rv64-max
LOG_LEVEL ?= 3

COMMON_DIR = ../common
SCRIPTS_DIR = ../scripts

# Configuration directory
CONFIG_DIR = $(COMMON_DIR)/config/$(CONFIG)

# Include configuration-specific build rules (platform.mk may override
# defaults such as XLEN, CROSS_COMPILER, QEMU_CPU, etc.)
include $(CONFIG_DIR)/platform.mk

# Framework fallback defaults (only apply if platform.mk did not set them)
XLEN     ?= 64

# Configuration headers (included via -include in CFLAGS/ASFLAGS)
CONFIG_PLATFORM_HEADER = $(CONFIG_DIR)/platform_config.h
CONFIG_RVTEST_HEADER   = $(CONFIG_DIR)/rvtest_config.h
CONFIG_MODEL_HEADER     = $(CONFIG_DIR)/rvmodel_macros.h

# All three configuration headers are mandatory for each platform.
# Header roles:
#   platform_config.h  -> C only    (injected via CFLAGS -include)
#   rvmodel_macros.h   -> C + Assembly (injected via both CFLAGS and ASFLAGS)
#   rvtest_config.h    -> Shared C + Assembly (injected via both)
# If any is missing, abort with a clear error message.
$(if $(wildcard $(CONFIG_PLATFORM_HEADER)),,$(error Missing required config header: $(CONFIG_PLATFORM_HEADER)))
$(if $(wildcard $(CONFIG_RVTEST_HEADER)),,$(error Missing required config header: $(CONFIG_RVTEST_HEADER)))
$(if $(wildcard $(CONFIG_MODEL_HEADER)),,$(error Missing required config header: $(CONFIG_MODEL_HEADER)))

# ABI selection
ifeq ($(XLEN),32)
    ABI   = ilp32
    MARCH = rv32imac_zicsr_zifencei
else
    ABI   = lp64
    MARCH = rv64imac_zicsr_zifencei
endif

# Toolchain
CC      = $(CROSS_COMPILER)gcc
AS      = $(CROSS_COMPILER)as
LD      = $(CROSS_COMPILER)ld
OBJCOPY = $(CROSS_COMPILER)objcopy
OBJDUMP = $(CROSS_COMPILER)objdump

# Common object files (built from common/ sources)
COMMON_OBJS = \
    $(COMMON_DIR)/entry.o \
    $(COMMON_DIR)/platform_init.o \
    $(COMMON_DIR)/trap_asm.o \
    $(COMMON_DIR)/trap.o \
    $(COMMON_DIR)/privilege.o \
    $(COMMON_DIR)/csr_accessors.o \
    $(COMMON_DIR)/uart.o \
    $(COMMON_DIR)/test_framework.o

# VM support (conditional, set ENABLE_VM=1 in extension Makefile)
ifdef ENABLE_VM
VM_DIR = $(COMMON_DIR)/vm
VM_OBJS = $(VM_DIR)/page_table.o $(VM_DIR)/satp.o
COMMON_OBJS += $(VM_OBJS)
endif

# PMP support (conditional, set ENABLE_PMP=1 in extension Makefile)
ifdef ENABLE_PMP
PMP_DIR_COMMON = $(COMMON_DIR)/pmp
PMP_OBJS = $(PMP_DIR_COMMON)/pmp_cfg.o $(PMP_DIR_COMMON)/pmp_init.o
COMMON_OBJS += $(PMP_OBJS)
endif

# Hypervisor (H ext) support (conditional, set ENABLE_HYP=1 in extension Makefile)
ifdef ENABLE_HYP
HYP_DIR  = $(COMMON_DIR)/hyp
HYP_OBJS = \
    $(HYP_DIR)/hyp_csr.o \
    $(HYP_DIR)/hyp_priv.o \
    $(HYP_DIR)/hyp_trap.o \
    $(HYP_DIR)/hyp_trap_asm.o \
    $(HYP_DIR)/hyp_fence.o \
    $(HYP_DIR)/hyp_ldst.o \
    $(HYP_DIR)/hyp_reset.o \
    $(HYP_DIR)/gstage_pt.o \
    $(HYP_DIR)/two_stage.o \
    $(HYP_DIR)/test_vs_helpers.o \
    $(HYP_DIR)/hyp_vs_trap.o \
    $(HYP_DIR)/hyp_platform.o
ifdef ENABLE_TWO_STAGE
HYP_OBJS += $(HYP_DIR)/two_stage_helpers.o
endif
COMMON_OBJS += $(HYP_OBJS)
# Append H extension to ISA string
ifeq ($(XLEN),32)
MARCH := rv32imach_zicsr_zifencei
else
MARCH := rv64imach_zicsr_zifencei
endif
endif

# PM (Pointer Masking) support (conditional, set ENABLE_PM=1 in extension Makefile)
ifdef ENABLE_PM
PM_DIR = $(COMMON_DIR)/pm
PM_OBJS = $(PM_DIR)/pm_cfg.o
COMMON_OBJS += $(PM_OBJS)
endif

# IOPMP support (conditional, set ENABLE_IOPMP=1 in extension Makefile)
ifdef ENABLE_IOPMP
IOPMP_DIR = $(COMMON_DIR)/iopmp
IOPMP_OBJS = $(IOPMP_DIR)/iopmp_cfg.o $(IOPMP_DIR)/iopmp_init.o
COMMON_OBJS += $(IOPMP_OBJS)
endif

# N-Trace (Nexus-based Trace) support (conditional, set ENABLE_NTRACE=1 in extension Makefile)
ifdef ENABLE_NTRACE
NTRACE_DIR = $(COMMON_DIR)/trace
NTRACE_OBJS = $(NTRACE_DIR)/trace_ctrl.o $(NTRACE_DIR)/ntrace_decoder.o
COMMON_OBJS += $(NTRACE_OBJS)
endif

# CMO (Cache Management Operations) support (conditional, set ENABLE_CMO=1 in extension Makefile)
ifdef ENABLE_CMO
CMO_DIR = $(COMMON_DIR)/cmo
endif

# Compiler flags
CFLAGS  = -Wall -O0 -g -fno-omit-frame-pointer -ggdb
CFLAGS += -march=$(MARCH) -mabi=$(ABI) -mcmodel=medany
CFLAGS += -ffreestanding -fno-common -nostdlib -mno-relax
CFLAGS += -I$(COMMON_DIR) -I.
# CFLAGS: platform_config.h (C-only) + rvmodel_macros.h (C + Assembly) + rvtest_config.h (shared)
CFLAGS += -include $(CONFIG_PLATFORM_HEADER)
CFLAGS += -include $(CONFIG_MODEL_HEADER)
CFLAGS += -include $(CONFIG_RVTEST_HEADER)
CFLAGS += -D LOG_LEVEL=$(LOG_LEVEL)
CFLAGS += -D MEM_BASE=$(MEM_BASE)
CFLAGS += -MMD -MP
CFLAGS += $(shell $(CC) -fno-stack-protector -E -x c /dev/null >/dev/null 2>&1 && echo -fno-stack-protector)

# Disable PIE
ifneq ($(shell $(CC) -dumpspecs 2>/dev/null | grep -e '[^f]no-pie'),)
CFLAGS += -fno-pie -no-pie
endif

# Conditional CFLAGS for PMP support
ifdef ENABLE_PMP
CFLAGS += -I$(PMP_DIR_COMMON)
endif

# Conditional CFLAGS for Hypervisor support
ifdef ENABLE_HYP
CFLAGS  += -DENABLE_HYP -I$(HYP_DIR)
endif

# Conditional CFLAGS for PM support
ifdef ENABLE_PM
CFLAGS += -DENABLE_PM -I$(PM_DIR)/..
endif

# Conditional CFLAGS for IOPMP support
ifdef ENABLE_IOPMP
CFLAGS += -DENABLE_IOPMP -I$(IOPMP_DIR)
endif

# Conditional CFLAGS for N-Trace support
ifdef ENABLE_NTRACE
CFLAGS += -DENABLE_NTRACE -I$(NTRACE_DIR)
endif

# Conditional CFLAGS for CMO support
ifdef ENABLE_CMO
CFLAGS += -DENABLE_CMO -I$(CMO_DIR)
endif

# Extra CFLAGS from command line (e.g., make qemu EXTRA_CFLAGS='-DTEST_FILTER="VS-10"')
CFLAGS += $(EXTRA_CFLAGS)

# Assembler flags
ASFLAGS  = -march=$(MARCH) -mabi=$(ABI)
ASFLAGS += -I$(COMMON_DIR) -I.
# ASFLAGS: rvmodel_macros.h (assembly-only) + rvtest_config.h (shared)
# platform_config.h is NOT included in ASFLAGS (C-only)
ASFLAGS += -include $(CONFIG_MODEL_HEADER)
ASFLAGS += -include $(CONFIG_RVTEST_HEADER)
ASFLAGS += -D MEM_BASE=$(MEM_BASE)

# Conditional ASFLAGS for PMP support
ifdef ENABLE_PMP
ASFLAGS += -DENABLE_PMP -I$(PMP_DIR_COMMON)
endif

# Conditional ASFLAGS for Hypervisor support
ifdef ENABLE_HYP
ASFLAGS += -DENABLE_HYP -I$(HYP_DIR)
endif

# Conditional ASFLAGS for PM support
ifdef ENABLE_PM
ASFLAGS += -DENABLE_PM -I$(PM_DIR)/..
endif

# Conditional ASFLAGS for IOPMP support
ifdef ENABLE_IOPMP
ASFLAGS += -DENABLE_IOPMP -I$(IOPMP_DIR)
endif

# Conditional ASFLAGS for N-Trace support
ifdef ENABLE_NTRACE
ASFLAGS += -DENABLE_NTRACE -I$(NTRACE_DIR)
endif

# Conditional ASFLAGS for CMO support
ifdef ENABLE_CMO
ASFLAGS += -DENABLE_CMO -I$(CMO_DIR)
endif

# Linker flags
LDFLAGS  = -z max-page-size=4096 -nostartfiles -nostdlib -nodefaultlibs
LDFLAGS += -Wl,--defsym=__riscv_xlen=$(XLEN)
LDFLAGS += -Wl,--defsym=MEM_BASE=$(MEM_BASE)
LDFLAGS += -Wl,--no-warn-rwx-segments
LDFLAGS += -L$(CONFIG_DIR)
LDFLAGS += -march=$(MARCH) -mabi=$(ABI)

# =====================================================================
# Compile rules (shared by both single and multi-target modes)
# =====================================================================

# C source -> object (common)
$(COMMON_DIR)/%.o: $(COMMON_DIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# Assembly source -> object (common)
$(COMMON_DIR)/%.o: $(COMMON_DIR)/%.S
	$(CC) $(ASFLAGS) -c $< -o $@

# C source -> object (extension)
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Assembly source -> object (extension)
%.o: %.S
	$(CC) $(ASFLAGS) -c $< -o $@

# =====================================================================
# Build targets
# =====================================================================

# Helper: convert filename to Make variable name (replace - and . with _)
_varname = $(subst -,_,$(subst .,_,$(1)))

ifdef TARGETS
# =================================================================
# Multi-target mode
# =================================================================
# Usage in extension Makefile:
#   TARGETS = pmp_cvpt.elf pmp_basic.elf pmp_lock.elf
#   pmp_cvpt_OBJS  = pmp_reset.o main_cvpt.o tests/register_cvpt.o
#   pmp_basic_OBJS = pmp_reset.o main_basic.o tests/register_basic.o
#   pmp_lock_OBJS  = pmp_reset.o main_lock.o tests/register_lock.o
#
# Each target links its own _OBJS + COMMON_OBJS against kernel.ld.
# All products remain in the same directory.
# =================================================================

.PHONY: all clean

all: $(TARGETS)

# Generate a link rule for each target
define MULTI_TARGET_RULE
$(1): $$($(call _varname,$(basename $(1)))_OBJS) $$(COMMON_OBJS) kernel.ld
	$$(CC) $$(LDFLAGS) -T kernel.ld -o $(1) $$($(call _varname,$(basename $(1)))_OBJS) $$(COMMON_OBJS)
	$$(OBJDUMP) -S $(1) > $(basename $(1)).asm
	$$(OBJDUMP) -t $(1) | sed '1,/SYMBOL TABLE/d; s/ .* / /; /^$$$$/ d' > $(basename $(1)).sym
endef

$(foreach target,$(TARGETS),$(eval $(call MULTI_TARGET_RULE,$(target))))

# Collect all extension objs across all targets (for clean)
_ALL_EXT_OBJS = $(sort $(foreach t,$(TARGETS),$($(call _varname,$(basename $(t)))_OBJS)))

clean:
	rm -f $(_ALL_EXT_OBJS) $(_ALL_EXT_OBJS:.o=.d)
	rm -f $(TARGETS)
	rm -f $(foreach t,$(TARGETS),$(basename $(t)).asm $(basename $(t)).sym)
	rm -f $(foreach t,$(TARGETS),$(basename $(t)).trace $(basename $(t)).rvvi)
	find $(COMMON_DIR) \( -name "*.o" -o -name "*.d" \) -type f -delete

else
# =================================================================
# Single-target mode (legacy, fully backward compatible)
# =================================================================

ALL_OBJS = $(COMMON_OBJS) $(EXT_OBJS)

.PHONY: all clean

all: $(TARGET)

# Strip .elf suffix for auxiliary file names (e.g., pmp_test.elf -> pmp_test.asm)
TARGET_BASE = $(basename $(TARGET))

$(TARGET): $(ALL_OBJS) kernel.ld
	$(CC) $(LDFLAGS) -T kernel.ld -o $(TARGET) $(ALL_OBJS)
	$(OBJDUMP) -S $(TARGET) > $(TARGET_BASE).asm
	$(OBJDUMP) -t $(TARGET) | sed '1,/SYMBOL TABLE/d; s/ .* / /; /^$$/d' > $(TARGET_BASE).sym

clean:
	rm -f $(ALL_OBJS) $(ALL_OBJS:.o=.d)
	rm -f $(TARGET) $(TARGET_BASE).asm $(TARGET_BASE).sym
	rm -f $(TARGET_BASE).trace $(TARGET_BASE).rvvi
	find $(COMMON_DIR) \( -name "*.o" -o -name "*.d" \) -type f -delete

endif # ifdef TARGETS

# =====================================================================
# Header dependency tracking (-MMD -MP generates .d files alongside .o)
# =====================================================================
-include $(COMMON_OBJS:.o=.d)
ifdef TARGETS
-include $(_ALL_EXT_OBJS:.o=.d)
else
-include $(EXT_OBJS:.o=.d)
endif

# =====================================================================
# Simulator targets
# =====================================================================

# --- QEMU ---
.PHONY: qemu

ifdef TARGETS
qemu:
	$(MAKE) CONFIG=qemu-rv64-max
	@for elf in $(TARGETS); do \
		echo "========== QEMU: $$elf =========="; \
		$(QEMU) -machine $(QEMU_MCH) -cpu $(QEMU_CPU) -bios none \
			-kernel $$elf -m $(QEMU_MEM) -smp $(QEMU_SMP) \
			-semihosting -nographic || exit 1; \
	done
else
qemu:
	$(MAKE) CONFIG=$(CONFIG)
	$(QEMU) $(QEMU_OPTS)
endif

# --- Sail ---
SAIL ?= sail_riscv_sim

.PHONY: sail

ifdef TARGETS
sail:
	$(MAKE) CONFIG=sail-rv64-max
	@for elf in $(TARGETS); do \
		echo "========== Sail: $$elf =========="; \
		$(SAIL) $$elf || exit 1; \
	done
else
sail:
	$(MAKE) CONFIG=sail-rv64-max
	$(SAIL) $(TARGET)
endif

# --- Trace ---
.PHONY: trace

ifdef TARGETS
trace:
	$(MAKE) CONFIG=sail-rv64-max
	@for elf in $(TARGETS); do \
		base=$$(basename $$elf .elf); \
		echo "========== Trace: $$elf =========="; \
		$(SAIL) --trace --trace-output $$base.trace $$elf || exit 1; \
		$(SCRIPTS_DIR)/sail_to_rvvi.py $$base.trace; \
	done
else
trace:
	$(MAKE) CONFIG=sail-rv64-max
	$(SAIL) --trace --trace-output $(basename $(TARGET)).trace $(TARGET)
	$(SCRIPTS_DIR)/sail_to_rvvi.py $(basename $(TARGET)).trace
endif

# --- Spike ---
SPIKE ?= spike

SPIKE_ISA_EXT ?=
SPIKE_ISA     ?= $(MARCH)$(SPIKE_ISA_EXT)

.PHONY: spike

ifdef TARGETS
spike:
	$(MAKE) CONFIG=spike-rv64-max
	@for elf in $(TARGETS); do \
		echo "========== Spike: $$elf =========="; \
		$(SPIKE) --isa=$(SPIKE_ISA) $$elf || exit 1; \
	done
else
spike:
	$(MAKE) CONFIG=spike-rv64-max
	$(SPIKE) --isa=$(SPIKE_ISA) $(TARGET)
endif

# --- Whisper ---
WHISPER ?= whisper
WHISPER_CONFIG = $(COMMON_DIR)/config/whisper-rv64-max/whisper.json

.PHONY: whisper

ifdef TARGETS
whisper:
	$(MAKE) CONFIG=whisper-rv64-max
	@for elf in $(TARGETS); do \
		echo "========== Whisper: $$elf =========="; \
		$(WHISPER) --config $(WHISPER_CONFIG) $$elf || exit 1; \
	done
else
whisper:
	$(MAKE) CONFIG=whisper-rv64-max
	$(WHISPER) --config $(WHISPER_CONFIG) $(TARGET)
endif
