{
  "clint": "0x2000000",

  "address_translation_pmms": ["off", "pm57"],

  "isa": "rv64imafdcvhus_zicbom_zicbop_zicboz_zicntr_zicond_zicsr_zihintpause_zihpm_zimop_zawrs_zfa_zfbfmin_zfh_zkr_zcb_zcmop_zba_zbb_zbs_zvbb_zvbc_zvfbfmin_zvfbfwma_zvfh_zvkg_zvkned_zvknhb_zvksed_zvksh_zvqdot_sdtrig_smaia_smstateen_ssaia_sscofpmf_sstc_svadu_svinval_svnapot_svpbmt_svvptc_zifencei_zabha_zbc_zkne_zknd_zknh_zbkb_zbkc_zbkx_zksed_zksh_zacas_zicfilp_zicfiss_smmpm_smnpm_ssnpm",

  "all_inst_addr_trigger": "false",
  "cancel_lr_on_trap": false,
  "clear_mtval_on_ebreak": false,
  "clear_mtval_on_illegal_instruction": false,
  "clear_tinst_on_cbo_flush": false,
  "clear_tinst_on_cbo_inval": false,
  "enable_pmp_na4": false,
  "enable_pmp_tor": true,
  "guest_interrupt_count": 5,
  "indexed_nmi": false,

  "memmap": {
    "pma": [
      {
        // Make address range 0 to 1023 non readable to support ACCESS_FAULT_ADDR in rvtest_config.h
        "attribs": [],
        "high": 1023,
        "low": 0
      }
    ],
    "consoleio": "0x10000000", // Matches virtual printer address in rvmodel_macros.h
    "Comment": "Set physical memory size to be 34-bits",
    "size": "0x400000000"
  },

  "csr": {
    "vstart": {
      "mask": "0xff",
      "poke_mask": "0xff"
    },
    "mstatus": {
      "mask": "0x000002cf00fe7faa",
      "poke_mask": "0x800002cf00fe7faa"
    },
    "mie": {
      "mask": "0x2aaa", // ensuring that all non writable bits remain as read only 0
      "poke_mask": "0x2aaa"
    },
    "mip": {
      "mask": "0x2222", // determines what bits of mip can be set by M-mode software [SEIP, STIP, SSIP]
      "poke_mask": "0x2aaa" //determines what bits of mip can be set by simulator injecting external events
    },
    "stvec": {
      "mask": "0xFFFFFFFFFFFFFFFD" // don't allow setting MODE field to 2 (reserved)
    },
    "mcounteren": {
      "mask": "0x00000007"
    },
    "scounteren": {
      "mask": "0x00000007"
    }
  },

  "misaligned_has_priority": false,
  "num_mmode_perf_regs": 8,
  "physical_memory_protection_grain": "0x1000",
  "reservation_bytes": 64,
  "reset_vec": "0x80000000",

  "trigger_actions": [
    "raisebreak",
    "enterdebug",
    "starttrace",
    "stoptrace",
    "emittrace"
  ],
  "aplic": {
    "num_sources": 2, // two sources (MEXT and SEXT)
    "domains": {
      "maplic": {
        "base": "0x0c000000",
        "size": "0x00100000",
        "parent": null,
        "is_machine": true,
        "hart_indices": [0],
        "child_index": 0
      },
      "saplic": {
        "base": "0x0d000000",
        "size": "0x00100000",
        "parent": "maplic",
        "is_machine": false,
        "hart_indices": [0],
        "child_index": 0 // child_index 0 under maplic
      }
    }
  },
  "vector": {
    "always_mark_dirty": true,
    "bytes_per_vec": 32,
    "fp_usum_nan_canonicalize": ["e16", "e32", "e64"],
    "legalize_for_egs": false,
    "legalize_vsetvl_avl": true,
    "legalize_vsetvli_avl": true,
    "mask_agnostic_policy": "ones",
    "max_bytes_per_elem": 8,
    "max_bytes_per_lmul": {
      "mf2": 4,
      "mf4": 2,
      "mf8": 1
    },
    "min_bytes_per_elem": 1,
    "partial_segment_update": false,
    "tail_agnostic_policy": "ones",
    "trap_invalid_vtype": false,
    "trap_non_zero_vstart": true,
    "tt_clear_tval_vl_egs": true,
    "tt_fp_usum_tree_reduction": ["e16", "e32", "e64"],
    "update_whole_mask": false
  },

  "wfi_timeout": 200
}
